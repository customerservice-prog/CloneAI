# Copy to .env and fill in. Never commit .env.
#
# ========== MINIMUM FOR RENDER (Docker) ==========
# OPENAI_API_KEY=sk-...
# NODE_ENV=production
# PORT=3001
# CORS_ORIGINS=https://siteclonerpro.com,https://www.siteclonerpro.com
# FRONTEND_URL=https://siteclonerpro.com
# BILLING_ENABLED=false
# (See docs/RENDER_EASY.md for click-by-click steps.)
# ================================================

# --- Security (production) ---
# Comma-separated exact frontend origins (no *). Required when NODE_ENV=production.
# CORS_ORIGINS=https://your-app.vercel.app
#
# Optional shared secret: all API routes require header X-CloneAI-Key when set.
# CLONEAI_INGRESS_KEY=
#
# Optional: GET /api/admin/ops-summary — send header x-cloneai-admin-key (JSON billing snapshot + crawl caps).
# ADMIN_OPS_KEY=
#
# Rate limits (per IP): global API default 60/min; /api/analyze default 10/min + daily cap.
# GLOBAL_RATE_LIMIT_PER_MINUTE=60
# RATE_LIMIT_PER_MINUTE=10
# RATE_LIMIT_DAILY_PER_IP=200
#
# JSON bodies (billing, analytics, etc.) — not multipart /api/analyze.
# JSON_BODY_LIMIT=8mb
#
# Cloudflare Turnstile: after first successful analyze per IP, further runs require token.
# TURNSTILE_SECRET_KEY=
# Frontend: VITE_TURNSTILE_SITE_KEY= (same Cloudflare widget)
#
# Behind TLS-terminating proxy: enforce HTTPS (uses X-Forwarded-Proto).
# RELAX_HTTPS_ENFORCEMENT=true   # local / unusual proxy only
#
# RELAX_ANALYZE_ORIGIN_CHECK=true  # emergency only; weakens POST /api/analyze origin binding

OPENAI_API_KEY=
# Optional (default gpt-4o):
# OPENAI_MODEL=gpt-4o
# OPENAI_MAX_TOKENS=8000
# OPENAI_STREAM_TIMEOUT_MS=180000
#
# Image harvest (defaults: no max image count, no ZIP total cap — private use)
# IMAGE_HARVEST_MAX=0
# IMAGE_HARVEST_ZIP_CAP=0
# IMAGE_HARVEST_MAX_BYTES=52428800
# IMAGE_HARVEST_CONCURRENCY=12
# MAX_HTML_BYTES=8388608
# CRAWL_MAX_PAGES=100
# CRAWL_PRO_MAX_PAGES=100
# HTML_MODEL_MAX_CHARS_PER_PAGE=80000
# MAX_ANALYSIS_IMAGES=8
# MAX_OPENAI_REQUEST_JSON_BYTES=14680064
# GLOBAL_ANALYZE_BURST_MAX=80
# GLOBAL_ANALYZE_BURST_WINDOW_MS=60000
# GLOBAL_ANALYZE_MAX_IN_FLIGHT=32
# Max in-memory ZIP download tokens (oldest evicted under pressure).
# MAX_SITE_ASSET_DOWNLOADS=2500
# ANALYZE_MAX_CONCURRENT_PER_USER=1
#
# Express trust proxy: unset = 1 hop in production only; TRUST_PROXY=false disables; TRUST_PROXY=2 = two proxy hops (CDN + ingress).
# TRUST_PROXY=1
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_STREAM_INCLUDE_USAGE=true
# CRAWL_FETCH_CONCURRENCY=20
# CRAWL_SCREENSHOT_CONCURRENCY=10
# ENABLE_PAGE_SCREENSHOTS=true
# ENABLE_INTERACTION_CRAWL=true
# INTERACTION_HUB_PAGES=12
# INTERACTION_THEME_CLICKS_PER_HUB=100
# INTERACTION_CHECKOUT_MAX_STEPS=15
# INTERACTION_EXTRA_URL_CAP=120
#
# --- Billing (Stripe) ---
# Set BILLING_ENABLED=true to enforce usage limits on /api/analyze (requires X-CloneAI-User-Id from the app).
# BILLING_ENABLED=false (default) disables limits for local dev.
# BILLING_ENABLED=true
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...   # $5/mo subscription in Stripe Dashboard
# STRIPE_PRICE_PRO=price_...       # $12/mo subscription
# STRIPE_PRICE_EXTRA_RUN=price_... # $3 one-time payment
# FRONTEND_URL=https://your-app.vercel.app
# Optional: persist billing JSON elsewhere (default: backend/data/billing.json)
# BILLING_DATA_PATH=/var/lib/cloneai/billing.json
#
# Optional owner promo (server-only): exact match on form field promoCode or header X-CloneAI-Promo-Code
# skips Stripe run quota when BILLING_ENABLED=true. Does not bypass rate limits, SSRF checks, or model cost.
# Use a strong secret; rotate if leaked. Never commit the real value in git.
# CLONEAI_PROMO_CODE=
#
# --- DFY leads (optional) ---
# LEADS_DATA_PATH=/var/lib/cloneai/leads.jsonl
# LEADS_WEBHOOK_URL=https://hooks.example.com/cloneai-leads
#
# --- Product analytics rate limit (optional) ---
# ANALYTICS_RATE_PER_MINUTE=90
