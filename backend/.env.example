# Copy to .env and fill in. Never commit .env.

OPENAI_API_KEY=
# Optional (default gpt-4o):
# OPENAI_MODEL=gpt-4o
# OPENAI_MAX_TOKENS=8000
# OPENAI_STREAM_TIMEOUT_MS=180000
#
# Image harvest (defaults: no max image count, no ZIP total cap — private use)
# IMAGE_HARVEST_MAX=0
# IMAGE_HARVEST_ZIP_CAP=0
# IMAGE_HARVEST_MAX_BYTES=52428800
# IMAGE_HARVEST_CONCURRENCY=12
# MAX_HTML_BYTES=8388608
# CRAWL_MAX_PAGES=100
# CRAWL_FETCH_CONCURRENCY=20
# CRAWL_SCREENSHOT_CONCURRENCY=10
# ENABLE_PAGE_SCREENSHOTS=true
# ENABLE_INTERACTION_CRAWL=true
# INTERACTION_HUB_PAGES=12
# INTERACTION_THEME_CLICKS_PER_HUB=100
# INTERACTION_CHECKOUT_MAX_STEPS=15
# INTERACTION_EXTRA_URL_CAP=120
#
# --- Billing (Stripe) ---
# Set BILLING_ENABLED=true to enforce usage limits on /api/analyze (requires X-CloneAI-User-Id from the app).
# BILLING_ENABLED=false (default) disables limits for local dev.
# BILLING_ENABLED=true
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...   # $5/mo subscription in Stripe Dashboard
# STRIPE_PRICE_PRO=price_...       # $12/mo subscription
# STRIPE_PRICE_EXTRA_RUN=price_... # $3 one-time payment
# FRONTEND_URL=https://your-app.vercel.app
# Optional: persist billing JSON elsewhere (default: backend/data/billing.json)
# BILLING_DATA_PATH=/var/lib/cloneai/billing.json
