# Copy to .env.local for Vite dev, or set these in your host (Vercel, Render Static, etc.).
# For local ≈ live parity, see `.env.local.example` (same keys; point VITE_API_URL at prod API if desired).
# Never commit real secrets.
#
# Production builds require VITE_API_URL with https:// (vite.config.js enforces). Use
# frontend/.env.production or Render env on cloneai-web (cloneai-mf0z.onrender.com + siteclonerpro.com).
# Local dev: optional; defaults to http://localhost:3001 in JS if unset.
# VITE_API_URL=http://localhost:3001

# Must match backend CLONEAI_INGRESS_KEY when that env is set (sent as X-CloneAI-Key).
# VITE_CLONEAI_KEY=

# If the API is served on the same origin as this app (reverse proxy), you can use:
# VITE_SAME_ORIGIN_API=true
# and omit VITE_API_URL in some setups (see main.js).

# Optional: meta name="cloneai-api-origin" in index.html or window.__CLONEAI_API_BASE__ before load.

# VITE_PUBLIC_APP_URL=https://siteclonerpro.com
# VITE_TURNSTILE_SITE_KEY=
#
# Subscriptions and one-time runs use Stripe on the API (no Stripe publishable key required in this SPA).
