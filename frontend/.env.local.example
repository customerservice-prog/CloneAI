# Copy to `.env.local` (gitignored) so `npm run dev` matches production behavior.
# Same variables as Vercel/Render static — only values differ (localhost vs live URLs).
#
# Point at your deployed API to behave like production while developing locally:
# VITE_API_URL=https://your-api.onrender.com
# VITE_CLONEAI_KEY=<same as CLONEAI_INGRESS_KEY on the API>
#
# Or use a local API (default in main.js is http://localhost:3001 when unset):
# VITE_API_URL=http://localhost:3001
#
# Public app URL for share links / footers (use dev origin if testing locally):
# VITE_PUBLIC_APP_URL=http://localhost:5173
#
# Optional — same as production if you test Turnstile locally:
# VITE_TURNSTILE_SITE_KEY=
