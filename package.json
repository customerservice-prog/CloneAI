{
  "name": "cloneai",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "npm run dev --prefix frontend",
    "test": "npm test --prefix backend",
    "smoke": "npm run smoke --prefix backend",
    "adversarial": "npm run adversarial --prefix backend",
    "image-pipeline": "npm run image-pipeline --prefix backend",
    "build": "npm run build --prefix frontend",
    "render:backend-with-spa": "node scripts/publish-spa-to-backend.mjs && npm ci --prefix backend --omit=dev && npm run playwright:install --prefix backend",
    "verify": "npm test --prefix backend && npm run build --prefix frontend",
    "verify-live": "npm run verify-live --prefix backend",
    "preflight": "npm run verify && npm run launch-check:dev",
    "launch-check": "npm run launch-check --prefix backend",
    "launch-check:dev": "npm run launch-check:dev --prefix backend",
    "launch-check:prod": "npm run launch-check:prod --prefix backend"
  }
}
